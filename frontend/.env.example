# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Required for NextAuth + Prisma
DATABASE_URL=file:./lib/prisma/dev.db
DIRECT_URL=file:./lib/prisma/dev.db
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Frontend URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (if using client-side)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# AI Provider API Keys (Required for question generation)
# Get these from:
# - Gemini: https://aistudio.google.com/app/apikey
# - Grok: https://console.xai.com/
# - Claude: https://console.anthropic.com/
GEMINI_API_KEY=your-gemini-api-key-here
GROK_API_KEY=your-grok-api-key-here
CLAUDE_API_KEY=your-claude-api-key-here

# Optional Services
NLP_API_URL=http://localhost:8000
NLP_ENABLED=true
OCR_SERVICE_URL=http://localhost:3000
